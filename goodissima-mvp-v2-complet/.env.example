# Goodissima local development
# Never commit real secrets in this file.

GOODISSIMA_ENV=local
GOODISSIMA_DEBUG_MODE=true

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase PostgreSQL for Prisma server-side access only.
# Use the local/dev database connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require"

# Supabase browser auth client. RLS must prevent direct table access.
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="SUPABASE_ANON_KEY"

# Server-side Supabase admin operations only.
SUPABASE_SERVICE_ROLE_KEY="SUPABASE_SERVICE_ROLE_KEY"

# Email provider.
RESEND_API_KEY=""
EMAIL_FROM="Goodissima <onboarding@resend.dev>"

# AI defaults: local/dev remains deterministic unless explicitly changed.
AI_PROVIDER=mock
AI_TEST_MODE=scenario
AI_EMBEDDING_PROVIDER=mock
MISTRAL_API_KEY=""
MISTRAL_MODEL=mistral-small-latest

# Embedding worker controls.
EMBEDDING_JOB_BATCH_SIZE=10
EMBEDDING_WORKER_FORCE_FAIL=0

# Feature flags.
FEATURE_AI=true
FEATURE_MATCHING=true
FEATURE_ANALYTICS=true
FEATURE_EXPERIMENTAL=true
