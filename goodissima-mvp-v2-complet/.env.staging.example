# Goodissima staging / Vercel Preview
# Never commit real secrets in this file.

GOODISSIMA_ENV=staging
GOODISSIMA_DEBUG_MODE=false

NEXT_PUBLIC_APP_URL=https://preview.goodissima.app

# Supabase staging PostgreSQL for Prisma server-side access only.
# Use the staging database connection string, not production.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require"

# Used by Prisma migrations / direct connections if needed.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require"

# Supabase server URL for future server-side use.
SUPABASE_URL="https://STAGING_PROJECT_REF.supabase.co"

# Supabase browser auth client. RLS must prevent direct table access.
NEXT_PUBLIC_SUPABASE_URL="https://STAGING_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="STAGING_SUPABASE_ANON_KEY"

# Server-side Supabase admin operations only.
SUPABASE_SERVICE_ROLE_KEY="STAGING_SUPABASE_SERVICE_ROLE_KEY"

# Email provider. Keep disabled unless internal email validation is required.
RESEND_API_KEY=""
EMAIL_FROM="Goodissima Staging <onboarding@resend.dev>"

# Staging must not call remote AI providers by default.
AI_PROVIDER=mock
AI_TEST_MODE=scenario
AI_EMBEDDING_PROVIDER=mock
MISTRAL_API_KEY=""
MISTRAL_MODEL=mistral-small-latest

# Embedding worker controls.
EMBEDDING_JOB_BATCH_SIZE=10
EMBEDDING_WORKER_FORCE_FAIL=0

# Feature flags.
PRIVATE_ACCESS_MODE=true
FEATURE_AI=true
FEATURE_MATCHING=true
FEATURE_ANALYTICS=true
FEATURE_EXPERIMENTAL=false
