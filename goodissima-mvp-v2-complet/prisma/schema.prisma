generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LinkStatus {
  ACTIVE
  DISABLED
  EXPIRED
  ARCHIVED
}

enum CaseStatus {
  NEW
  IN_DISCUSSION
  VALIDATED
  REFUSED
  CLOSED
}

enum RelationPriority {
  NORMAL
  HIGH
  URGENT
}

enum RelationStatus {
  NEW
  WAITING_CANDIDATE
  WAITING_OWNER
  REVIEWING
  VALIDATED
  REJECTED
  CLOSED
  ARCHIVED
}

enum RelationGovernanceStatus {
  ACTIVE
  SUSPENDED
  CLOSED
  BLOCKED
}

enum SenderType {
  OWNER
  CANDIDATE
  SYSTEM
}

enum AccessInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum TrustPolicyScope {
  TEMPLATE
  GLINK
  RELATION_CASE
}

enum TrustPolicyAccessMode {
  PUBLIC_LINK
  INVITED_OWNER_ONLY
  TOKEN_HOLDER
  MANUAL_REVIEW
}

enum TrustPolicyStatus {
  ACTIVE
  DISABLED
}

enum CredentialTypeStatus {
  ACTIVE
  DISABLED
}

enum TrustedOrganizationStatus {
  PENDING
  TRUSTED
  SUSPENDED
  REVOKED
}

enum TrustConnectorStatus {
  ACTIVE
  DISABLED
}

enum TrustConnectorProviderType {
  DEMO
  GOVERNMENT
  EUROPEAN_WALLET
  BANK
  INSURANCE
  EDUCATION
  PROFESSIONAL_BODY
  OTHER
}

enum IdentityType {
  PERSON
  ORGANIZATION
}

enum IdentityStatus {
  UNVERIFIED
  VERIFIED
  SUSPENDED
  REVOKED
}

enum TrustCredentialStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  REVOKED
}

enum TrustClaimType {
  STRING
  BOOLEAN
  INTEGER
  DECIMAL
  DATE
  DATETIME
  JSON
}

enum TrustAdmissionTokenStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum TrustAdmissionTokenPurpose {
  TRUST_ADMISSION
}

enum LinkAdmissionMode {
  OPEN
  VERIFIED_ONLY
}

enum ProductFeedbackStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  IGNORED
}

enum GovernedJourneyInvitationRole {
  EXPERT
  JUDGE
  THIRD_PARTY
  ASSOCIATION
  FAMILY
  OBSERVER
  OTHER
}

enum GovernedJourneyInvitationStatus {
  PREPARED
  ACTIVE
  REVOKED
  EXPIRED
}

enum WorkspaceKind {
  GOVERNANCE
  RELATION
  MIXED
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
}

enum WorkspaceCategory {
  PROFESSIONAL
  PRIVATE
  FAMILY
  ASSOCIATION
  PROJECT
  CLIENT
  OTHER
}

enum PortfolioKind {
  JUDICIAL
  PROFESSIONAL
  ASSOCIATION
  FAMILY
  PROJECT
  PERSONAL
  OTHER
}

enum PortfolioStatus {
  ACTIVE
  ARCHIVED
}

enum CommunicationChannelType {
  VOICE_IP
  VIDEO_IP
  SCREEN_SHARE
}

enum CommunicationSessionStatus {
  REQUESTED
  PREPARED_NOT_STARTED
  CANCELLED
  COMPLETED
}

enum CommunicationProvider {
  NONE
  MANUAL_EXTERNAL
  LIVEKIT_PENDING
}

enum GovernedMeetingParticipantStatus {
  AUTHORIZED
  REMOVED
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  name                 String?
  role                 String   @default("OWNER")
  goodissimaIdentityId String?  @unique
  createdAt            DateTime @default(now())

  links                   GLink[]
  cases                   RelationCase[]              @relation("OwnerCases")
  portfolios              Portfolio[]                  @relation("OwnerPortfolios")
  workspaces              Workspace[]                 @relation("OwnerWorkspaces")
  communicationSessions   CommunicationSession[]
  authorizedMeetingParticipants GovernedMeetingParticipant[] @relation("MeetingParticipantAuthorizer")
  goodissimaIdentity      GoodissimaIdentity?         @relation(fields: [goodissimaIdentityId], references: [id], onDelete: SetNull)
  notificationPreferences UserNotificationPreference?
  templateGenerations     TemplateGeneration[]
  templateCriticReports   TemplateCriticReport[]
  templateOptimizations   TemplateOptimization[]
  aiEvents                AIEvent[]
  manualTemplateEditAudits ManualTemplateEditAudit[]
  productFeedback         ProductFeedback[]
}

model Portfolio {
  id          String          @id @default(cuid())
  ownerId     String
  slug        String
  name        String
  description String?
  kind        PortfolioKind   @default(OTHER)
  status      PortfolioStatus @default(ACTIVE)
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  owner      User        @relation("OwnerPortfolios", fields: [ownerId], references: [id], onDelete: Cascade)
  workspaces Workspace[]

  @@unique([ownerId, slug])
  @@index([ownerId, status, createdAt])
  @@index([ownerId, kind, status])
}

model Workspace {
  id          String          @id @default(cuid())
  ownerId     String
  portfolioId String?
  slug        String
  name        String
  description String?
  kind        WorkspaceKind   @default(GOVERNANCE)
  category    WorkspaceCategory @default(OTHER)
  status      WorkspaceStatus @default(ACTIVE)
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  owner             User               @relation("OwnerWorkspaces", fields: [ownerId], references: [id], onDelete: Cascade)
  portfolio         Portfolio?         @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  relationTemplates RelationTemplate[]
  relationCases     RelationCase[]
  links             GLink[]
  communicationSessions CommunicationSession[]
  governedJourneyInvitations GovernedJourneyInvitation[]

  @@unique([ownerId, slug])
  @@index([portfolioId])
  @@index([ownerId, status, createdAt])
  @@index([ownerId, category, status])
  @@index([kind, status])
}

model GovernedJourneyInvitation {
  id String @id @default(cuid())
  ownerId String
  workspaceId String?
  relationTemplateId String
  relationCaseId String?
  displayName String
  role GovernedJourneyInvitationRole
  status GovernedJourneyInvitationStatus @default(ACTIVE)
  accessTokenHash String @unique
  accessTokenExpiresAt DateTime
  revokedAt DateTime?
  acceptedAt DateTime?
  lastAccessedAt DateTime?
  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  relationTemplate RelationTemplate @relation(fields: [relationTemplateId], references: [id], onDelete: Cascade)
  relationCase RelationCase? @relation(fields: [relationCaseId], references: [id], onDelete: SetNull)
  meetingParticipants GovernedMeetingParticipant[]

  @@index([ownerId, relationTemplateId, status])
  @@index([accessTokenExpiresAt, status])
}

model CommunicationSession {
  id        String @id @default(cuid())
  ownerId   String
  workspaceId String?
  relationTemplateId String?
  relationCaseId String?
  channelType CommunicationChannelType
  provider CommunicationProvider @default(NONE)
  status CommunicationSessionStatus @default(PREPARED_NOT_STARTED)
  title String
  purpose String?
  note String?
  externalUrl String?
  scheduledAt DateTime?
  expiresAt DateTime?
  transcriptionRequested Boolean @default(false)
  transcriptionConsented Boolean @default(false)
  recordingEnabled Boolean @default(false)
  automaticNotificationSent Boolean @default(false)
  tokenGenerated Boolean @default(false)
  accessOpened Boolean @default(false)
  workflowStarted Boolean @default(false)
  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  relationTemplate RelationTemplate? @relation(fields: [relationTemplateId], references: [id], onDelete: SetNull)
  relationCase RelationCase? @relation(fields: [relationCaseId], references: [id], onDelete: SetNull)
  meetingParticipants GovernedMeetingParticipant[]

  @@index([ownerId, status, createdAt])
  @@index([workspaceId, status])
  @@index([relationTemplateId, status])
  @@index([relationCaseId, status])
  @@index([channelType, status])
}

model GovernedMeetingParticipant {
  id String @id @default(cuid())
  communicationSessionId String
  governedJourneyInvitationId String
  status GovernedMeetingParticipantStatus @default(AUTHORIZED)
  authorizedAt DateTime @default(now())
  removedAt DateTime?
  authorizedById String?
  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  communicationSession CommunicationSession @relation(fields: [communicationSessionId], references: [id], onDelete: Cascade)
  governedJourneyInvitation GovernedJourneyInvitation @relation(fields: [governedJourneyInvitationId], references: [id], onDelete: Cascade)
  authorizedBy User? @relation("MeetingParticipantAuthorizer", fields: [authorizedById], references: [id], onDelete: SetNull)

  @@unique([communicationSessionId, governedJourneyInvitationId])
  @@index([governedJourneyInvitationId, status])
}

model AccessInvitation {
  id              String                 @id @default(cuid())
  email           String                 @unique
  invitedByUserId String?
  status          AccessInvitationStatus @default(PENDING)
  note            String?
  token           String?
  expiresAt       DateTime?
  acceptedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([status, createdAt])
}

model UserNotificationPreference {
  id     String @id @default(cuid())
  userId String @unique

  emailNotificationsEnabled Boolean @default(false)
  newMessagesEnabled        Boolean @default(false)
  newRequestsEnabled        Boolean @default(false)
  newDocumentsEnabled       Boolean @default(false)
  validationsEnabled        Boolean @default(false)
  relationalPrivacyEnabled  Boolean @default(true)
  pseudonymizationEnabled   Boolean @default(true)
  frequency                 String  @default("IMMEDIATE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GLink {
  id                String     @id @default(cuid())
  ownerId           String
  workspaceId       String?
  templateId        String?
  templateVersionId String?
  slug              String     @unique
  title             String
  city              String?
  description       String?
  rules             Json?
  status            LinkStatus @default(ACTIVE)
  admissionMode     LinkAdmissionMode @default(OPEN)
  createdAt         DateTime   @default(now())
  expiresAt         DateTime?

  owner                User                  @relation(fields: [ownerId], references: [id])
  workspace            Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  template             RelationTemplate?     @relation(fields: [templateId], references: [id])
  templateVersion      TemplateVersion?      @relation(fields: [templateVersionId], references: [id])
  cases                RelationCase[]
  trustPolicies        TrustPolicy[]
  trustAdmissionTokens TrustAdmissionToken[]

  @@index([workspaceId])
}

model RelationCase {
  id                                 String                   @id @default(cuid())
  gLinkId                            String
  ownerId                            String
  workspaceId                        String?
  templateId                         String?
  candidateIdentityId                String?
  candidateAccessToken               String                   @unique
  candidateAccessExpiresAt           DateTime?
  candidateAccessRevokedAt           DateTime?
  candidateName                      String
  candidateEmail                     String
  candidateEmailNotificationsEnabled Boolean                  @default(false)
  matchingEnabled                    Boolean                  @default(false)
  embeddingStatus                    String                   @default("fresh")
  embeddingUpdatedAt                 DateTime?
  priority                           RelationPriority         @default(NORMAL)
  status                             RelationStatus           @default(NEW)
  governanceStatus                   RelationGovernanceStatus @default(ACTIVE)
  governanceUpdatedAt                DateTime?
  governanceReason                   String?
  currentStep                        String?                  @default("CONVERSATION")
  createdAt                          DateTime                 @default(now())
  closedAt                           DateTime?

  gLink             GLink               @relation(fields: [gLinkId], references: [id])
  owner             User                @relation("OwnerCases", fields: [ownerId], references: [id])
  workspace         Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  governedJourneyInvitations GovernedJourneyInvitation[]
  template          RelationTemplate?   @relation(fields: [templateId], references: [id])
  candidateIdentity GoodissimaIdentity? @relation(fields: [candidateIdentityId], references: [id], onDelete: SetNull)
  messages          Message[]
  documents         Document[]
  auditLogs         AuditLog[]
  relationEvents    RelationEvent[]
  relationActions   RelationAction[]
  formSubmissions   FormSubmission[]
  aiEvents          AIEvent[]
  embeddings        RelationEmbedding[]
  embeddingJobs     EmbeddingJob[]
  trustPolicies     TrustPolicy[]
  productFeedback   ProductFeedback[]
  communicationSessions CommunicationSession[]

  @@index([governanceStatus])
  @@index([candidateIdentityId])
  @@index([workspaceId])
}

model EmbeddingJob {
  id String @id @default(cuid())

  relationCaseId String
  relationCase   RelationCase @relation(fields: [relationCaseId], references: [id], onDelete: Cascade)

  status      String  @default("pending")
  triggerType String
  attempts    Int     @default(0)
  lastError   String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  processedAt DateTime?

  @@index([status, createdAt])
  @@index([relationCaseId, status])
}

model RelationEmbedding {
  id String @id @default(cuid())

  relationCaseId String
  relationCase   RelationCase @relation(fields: [relationCaseId], references: [id], onDelete: Cascade)

  embeddingType String
  contentHash   String
  vector        Unsupported("vector")?

  createdAt DateTime @default(now())

  @@index([relationCaseId, embeddingType])
  @@index([contentHash])
}

model RelationTemplate {
  id             String  @id @default(cuid())
  workspaceId    String?
  key            String  @unique
  name           String
  description    String?
  isDefault      Boolean @default(false)
  status         String  @default("DRAFT")
  aiInstructions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  relationCases RelationCase[]
  links         GLink[]
  formTemplates FormTemplate[]
  versions      TemplateVersion[]
  trustPolicies TrustPolicy[]
  generations   TemplateGeneration[]
  aiEvents      AIEvent[]
  productFeedback ProductFeedback[]
  communicationSessions CommunicationSession[]
  governedJourneyInvitations GovernedJourneyInvitation[]

  @@index([workspaceId])
}

model ProductFeedback {
  id           String                @id @default(cuid())
  type         String
  message      String
  page         String?
  role         String?
  userId       String?
  caseId       String?
  templateId   String?
  browserInfo  Json?
  environment  String?
  status       ProductFeedbackStatus @default(NEW)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  resolvedAt   DateTime?
  adminNotes   String?

  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  case     RelationCase?     @relation(fields: [caseId], references: [id], onDelete: SetNull)
  template RelationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  attachments ProductFeedbackAttachment[]

  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([userId])
  @@index([caseId])
  @@index([templateId])
}

model ProductFeedbackAttachment {
  id         String          @id @default(cuid())
  feedbackId String
  fileName   String
  fileUrl    String
  mimeType   String
  fileSize   Int
  width      Int?
  height     Int?
  annotation Json?
  createdAt  DateTime        @default(now())

  feedback ProductFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
  @@index([createdAt])
}

model TemplateGeneration {
  id String @id @default(cuid())

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  templateId String?
  template   RelationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  aiEventId String?  @unique
  aiEvent   AIEvent? @relation(fields: [aiEventId], references: [id], onDelete: SetNull)

  parentGenerationId String?
  parentGeneration   TemplateGeneration?  @relation("TemplateGenerationRevisions", fields: [parentGenerationId], references: [id], onDelete: SetNull)
  revisions          TemplateGeneration[] @relation("TemplateGenerationRevisions")

  inputDescription String
  language         String    @default("fr")
  output           Json
  provider         String
  model            String?
  promptVersion    String
  proposalVersion  Int       @default(1)
  revisionFeedback String?
  changes          Json?
  status           String    @default("GENERATED")
  validatedAt      DateTime?
  createdAt        DateTime  @default(now())

  @@index([createdById, createdAt])
  @@index([templateId])
  @@index([parentGenerationId])
}

model TrustPolicy {
  id String @id @default(cuid())

  scope          TrustPolicyScope
  templateId     String?
  gLinkId        String?
  relationCaseId String?

  accessMode              TrustPolicyAccessMode @default(PUBLIC_LINK)
  candidateCanRead        Boolean               @default(true)
  candidateCanWrite       Boolean               @default(true)
  ownerCanRead            Boolean               @default(true)
  ownerCanWrite           Boolean               @default(true)
  requireCandidateEmail   Boolean               @default(true)
  requireCandidateConsent Boolean               @default(false)
  allowDocuments          Boolean               @default(true)
  candidateTokenTtlDays   Int                   @default(30)
  status                  TrustPolicyStatus     @default(ACTIVE)
  reason                  String?
  version                 Int                   @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template               RelationTemplate?                  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  gLink                  GLink?                             @relation(fields: [gLinkId], references: [id], onDelete: SetNull)
  relationCase           RelationCase?                      @relation(fields: [relationCaseId], references: [id], onDelete: SetNull)
  credentialRequirements TrustPolicyCredentialRequirement[]

  @@index([scope, status])
  @@index([templateId])
  @@index([gLinkId])
  @@index([relationCaseId])
}

model CredentialType {
  id          String               @id @default(cuid())
  code        String               @unique
  name        String
  description String?
  status      CredentialTypeStatus
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  credentials             TrustCredential[]
  trustPolicyRequirements TrustPolicyCredentialRequirement[]
}

model TrustedOrganization {
  id             String                    @id @default(cuid())
  organizationId String
  status         TrustedOrganizationStatus
  approvedAt     DateTime?
  approvedBy     String?
  reason         String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  issuedCredentials TrustCredential[]
  trustConnectors   TrustConnector[]

  @@index([organizationId])
  @@index([status])
}

model TrustConnector {
  id                    String                     @id @default(cuid())
  code                  String                     @unique
  name                  String
  description           String?
  status                TrustConnectorStatus
  providerType          TrustConnectorProviderType
  trustedOrganizationId String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  trustedOrganization TrustedOrganization? @relation(fields: [trustedOrganizationId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([providerType])
  @@index([trustedOrganizationId])
}

model GoodissimaIdentity {
  id        String         @id @default(cuid())
  type      IdentityType
  status    IdentityStatus
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user                   User?
  credentials            TrustCredential[]
  trustAdmissionTokens   TrustAdmissionToken[]
  candidateRelationCases RelationCase[]
}

model TrustAdmissionToken {
  id         String                     @id @default(cuid())
  tokenHash  String                     @unique
  identityId String
  gLinkId    String?
  purpose    TrustAdmissionTokenPurpose
  status     TrustAdmissionTokenStatus
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  identity GoodissimaIdentity @relation(fields: [identityId], references: [id])
  gLink    GLink?             @relation(fields: [gLinkId], references: [id], onDelete: SetNull)

  @@index([identityId])
  @@index([gLinkId])
  @@index([status])
  @@index([expiresAt])
}

model TrustPolicyCredentialRequirement {
  id               String   @id @default(cuid())
  trustPolicyId    String
  credentialTypeId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  trustPolicy    TrustPolicy    @relation(fields: [trustPolicyId], references: [id], onDelete: Cascade)
  credentialType CredentialType @relation(fields: [credentialTypeId], references: [id], onDelete: Restrict)

  @@unique([trustPolicyId, credentialTypeId])
  @@index([trustPolicyId])
  @@index([credentialTypeId])
}

model TrustCredential {
  id                          String                @id @default(cuid())
  identityId                  String
  credentialTypeId            String
  issuerTrustedOrganizationId String
  status                      TrustCredentialStatus
  issuedAt                    DateTime
  expiresAt                   DateTime?
  revokedAt                   DateTime?
  revocationReason            String?
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt

  identity                  GoodissimaIdentity  @relation(fields: [identityId], references: [id])
  credentialType            CredentialType      @relation(fields: [credentialTypeId], references: [id])
  issuerTrustedOrganization TrustedOrganization @relation(fields: [issuerTrustedOrganizationId], references: [id])
  claims                    TrustClaim[]

  @@index([identityId])
  @@index([credentialTypeId])
  @@index([issuerTrustedOrganizationId])
  @@index([status])
}

model TrustClaim {
  id           String         @id @default(cuid())
  credentialId String
  claimKey     String
  claimType    TrustClaimType
  claimValue   Json
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  credential TrustCredential @relation(fields: [credentialId], references: [id])

  @@index([credentialId])
  @@index([claimKey])
}

model AIEvent {
  id String @id @default(cuid())

  caseId String?
  case   RelationCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  templateId String?
  template   RelationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  organizationId   String?
  organizationName String?
  featureName      String?

  provider String
  model    String?
  action   String
  status   String

  promptVersion String?
  outputSummary String?
  errorCode     String?

  tokensInput      Int?
  tokensOutput     Int?
  promptTokens     Int?
  completionTokens Int?
  estimatedCostEur Decimal? @db.Decimal(12, 6)
  latencyMs        Int?

  createdAt DateTime @default(now())

  templateGeneration TemplateGeneration?

  @@index([caseId, createdAt])
  @@index([provider, action, createdAt])
  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([featureName, createdAt])
  @@index([templateId, createdAt])
}

model TemplateVersion {
  id String @id @default(cuid())

  templateId String
  template   RelationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  version Int

  name        String
  description String?

  snapshot Json

  isPublished Boolean @default(false)

  createdAt DateTime @default(now())

  links               GLink[]
  criticReports       TemplateCriticReport[]
  optimizationSources TemplateOptimization[] @relation("OptimizationSourceVersion")
  optimizationDrafts  TemplateOptimization[] @relation("OptimizationDraftVersion")
  manualEditSources   ManualTemplateEditAudit[] @relation("ManualEditSourceVersion")
  manualEditResults   ManualTemplateEditAudit[] @relation("ManualEditNewVersion")

  @@unique([templateId, version])
}

model ManualTemplateEditAudit {
  id String @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  sourceVersionId String
  sourceVersion   TemplateVersion @relation("ManualEditSourceVersion", fields: [sourceVersionId], references: [id], onDelete: Cascade)

  newVersionId String @unique
  newVersion   TemplateVersion @relation("ManualEditNewVersion", fields: [newVersionId], references: [id], onDelete: Cascade)

  changeType   String
  changedFields Json
  reason       String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sourceVersionId, createdAt])
}

model TemplateCriticReport {
  id String @id @default(cuid())

  templateVersionId String
  templateVersion   TemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  criticVersion String
  score         Int
  report        Json
  createdAt     DateTime @default(now())

  optimizations TemplateOptimization[]

  @@index([templateVersionId, createdAt])
  @@index([createdById, createdAt])
}

model TemplateOptimization {
  id String @id @default(cuid())

  criticReportId String
  criticReport   TemplateCriticReport @relation(fields: [criticReportId], references: [id], onDelete: Cascade)

  sourceVersionId String
  sourceVersion   TemplateVersion @relation("OptimizationSourceVersion", fields: [sourceVersionId], references: [id], onDelete: Cascade)

  draftVersionId String?          @unique
  draftVersion   TemplateVersion? @relation("OptimizationDraftVersion", fields: [draftVersionId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  optimizerVersion String
  language         String    @default("fr")
  status           String    @default("PROPOSED")
  originalScore    Int
  projectedScore   Int
  proposal         Json
  provenance       Json
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())

  @@index([criticReportId, createdAt])
  @@index([sourceVersionId, createdAt])
  @@index([createdById, createdAt])
}

model FormTemplate {
  id String @id @default(cuid())

  key         String  @unique
  name        String
  description String?

  relationTemplateId String?
  relationTemplate   RelationTemplate? @relation(fields: [relationTemplateId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields      FormField[]
  submissions FormSubmission[]
}

model FormField {
  id String @id @default(cuid())

  formTemplateId String
  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)

  key   String
  label String

  type     String
  required Boolean @default(false)

  placeholder  String?
  defaultValue String?

  position Int @default(0)
  step     Int @default(1)

  options          Json?
  validationRules  Json?
  conditionalRules Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([formTemplateId, position])
}

model FormSubmission {
  id String @id @default(cuid())

  formTemplateId String
  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id])

  caseId String?
  case   RelationCase? @relation(fields: [caseId], references: [id])

  answers Json

  createdAt DateTime @default(now())
}

model RelationEvent {
  id String @id @default(cuid())

  caseId String
  case   RelationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  type      String
  actorType String?
  actorId   String?

  payload Json?

  createdAt DateTime @default(now())

  @@index([caseId, createdAt])
}

model RelationAction {
  id String @id @default(cuid())

  relationCaseId String
  relationCase   RelationCase @relation(fields: [relationCaseId], references: [id], onDelete: Cascade)

  type String

  status String @default("PENDING")

  title       String
  description String?

  payload Json?

  createdByRole String

  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([relationCaseId, status])
  @@index([relationCaseId, createdAt])
}

model Message {
  id          String     @id @default(cuid())
  caseId      String
  senderType  SenderType
  senderEmail String
  body        String
  createdAt   DateTime   @default(now())

  relationCase RelationCase @relation(fields: [caseId], references: [id])
}

model Document {
  id              String   @id @default(cuid())
  caseId          String
  uploadedByEmail String
  fileName        String
  fileUrl         String
  mimeType        String?
  createdAt       DateTime @default(now())

  relationCase RelationCase @relation(fields: [caseId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  caseId     String?
  actorEmail String?
  eventType  String
  metadata   Json?
  createdAt  DateTime @default(now())

  relationCase RelationCase? @relation(fields: [caseId], references: [id])
}
